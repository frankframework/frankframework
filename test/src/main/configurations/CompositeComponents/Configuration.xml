<Configuration
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:noNamespaceSchemaLocation="https://schemas.frankframework.org/FrankConfig.xsd"
	active="${plugins.enabled}">

	<Adapter name="testPipelinePartFromPlugin">
		<Receiver>
			<JavaListener name="testPlugin" />
		</Receiver>
		<Pipeline>
			<Exits>
				<Exit name="EXIT" state="SUCCESS" />
				<Exit name="ERROR" state="ERROR" />
			</Exits>

			<!-- custom pipe of sender (in plugin) -->
			<CompositePipe name="callPluginAsPipe" plugin="demo-plugin" />

			<SwitchPipe name="if success">
				<Forward name="Niels was here!" path="forLoop" />
				<Forward name="notFound" path="ERROR" />
			</SwitchPipe>

			<SenderPipe name="callPluginAsSender">
				<CompositeSender name="plugin" plugin="demo-plugin" ref="demo-test-part.xml" />
			</SenderPipe>
		</Pipeline>
	</Adapter>
</Configuration>
