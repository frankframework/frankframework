<Module>
	<Adapter name="writeIbisstore">
		<Receiver name="writeIbisstoreReceiver">
			<JavaListener name="writeIbisstoreListener" serviceName="ibis4test-WriteToMessageStore" />
			<JdbcErrorStorage slotId="TestMessageStoreSenderAndListener-WriteErrors" />
		</Receiver>
		<Pipeline>
			<Exits>
				<Exit name="EXIT" state="SUCCESS" code="200" />
			</Exits>

			<PutInSessionPipe name="prepareSessionKeys">
				<Param name="key1" value="a,b,c"/>
				<Param name="key2" value="double quote: [&quot;] single quote [']"/>
			</PutInSessionPipe>
			<SenderPipe name="sendMessagePipe">
				<JdbcMessageLog slotId="TestMessageStoreSenderAndListener-WriteLog" />
				<MessageStoreSender
					slotId="TestMessageStoreSenderAndListener-Queue"
					sessionKeys="key1,key2">
					<Param name="messageId" xpathExpression="/Envelope/Header/MessageID" />
				</MessageStoreSender>
				<Forward name="success" path="EXIT" />
			</SenderPipe>
		</Pipeline>
	</Adapter>
	<Adapter name="readIbisstore">
		<Receiver name="readIbisstoreReceiver" pollInterval="1" maxRetries="-1">
			<MessageStoreListener name="MyListener"
				slotId="TestMessageStoreSenderAndListener-Queue"
				sessionKeys="key1,key2" />
		</Receiver>
		<Pipeline>
			<InputValidator className="org.frankframework.pipes.XmlValidator"
				schema="xsd/any.xsd"
				root="Envelope"
				throwException="true">
			</InputValidator>

			<Exits>
				<Exit name="EXIT" state="SUCCESS" code="200" />
			</Exits>

			<XsltPipe name="collectResults" xpathExpression="concat('original message [',$msg,'] key1 [',$k1,'] key2 [',$k2,']')" >
				<Param name="msg" sessionKey="originalMessage" />
				<Param name="k1" sessionKey="key1" />
				<Param name="k2" sessionKey="key2" />
				<Forward name="success" path="EXIT" />
			</XsltPipe>
		</Pipeline>
	</Adapter>

	<Adapter name="testMessageStoreNoMessageLog">
		<Receiver name="WriteToMessageStoreNoLog">
			<JavaListener name="WriteToMessageStoreNoLog" serviceName="ibis4test-WriteToMessageStoreNoLog"  />
		</Receiver>
		<Pipeline>
			<Exits>
				<Exit name="EXIT" state="SUCCESS" code="200" />
			</Exits>

			<SenderPipe name="sendMessagePipe">
				<MessageStoreSender
					slotId="TestMessageStoreSenderAndListener-NoLog" />
				<Forward name="success" path="EXIT" />
			</SenderPipe>
		</Pipeline>
	</Adapter>
	<Adapter name="testReadMessageStoreNoMessageLog">
		<Receiver name="testReadMessageStoreNoMessageLog" pollInterval="1" maxRetries="0">
			<MessageStoreListener name="testReadMessageStoreNoMessageLog"
				slotId="TestMessageStoreSenderAndListener-NoLog"
				moveToMessageLog="false" />
		</Receiver>
		<Pipeline>
			<Exits>
				<Exit name="EXIT" state="SUCCESS" code="200" />
				<Exit name="EXCEPTION" state="ERROR" />
			</Exits>

			<ExceptionPipe name="error" />
		</Pipeline>
	</Adapter>

	<Adapter name="writeIbisstoreWithCidXsl">
		<Receiver name="writeIbisstoreReceiverWithCidXsl">
			<JavaListener name="writeIbisstoreListenerWithCidXsl" serviceName="ibis4test-WriteToMessageStoreWithCidXsl"/>
			<JdbcErrorStorage slotId="TestMessageStoreSenderAndListener-WriteErrors"/>
		</Receiver>
		<Pipeline>
			<Exits>
				<Exit name="EXIT" state="SUCCESS" code="200"/>
			</Exits>

			<SenderPipe name="sendMessagePipe">
				<JdbcMessageLog slotId="TestMessageStoreSenderAndListener-WriteLog"/>
				<MessageStoreSender
					slotId="TestMessageStoreSenderAndListener-Queue"
					sessionKeys="key1,key2">
					<Param name="correlationId" styleSheetName="MessageStoreSenderAndListener/extractCorrelationId.xsl"/>
				</MessageStoreSender>
				<Forward name="success" path="EXIT"/>
			</SenderPipe>
		</Pipeline>
	</Adapter>

	<Adapter name="writeIbisstoreWithCid">
		<Receiver name="writeIbisstoreReceiverWithCid">
			<JavaListener name="writeIbisstoreListenerWithCid" serviceName="ibis4test-WriteToMessageStoreWithCid"/>
			<JdbcErrorStorage slotId="TestMessageStoreSenderAndListener-WriteErrors"/>
		</Receiver>
		<Pipeline>
			<Exits>
				<Exit name="EXIT" state="SUCCESS" code="200"/>
			</Exits>

			<SenderPipe name="sendMessagePipe">
				<JdbcMessageLog slotId="TestMessageStoreSenderAndListener-WriteLog"/>
				<MessageStoreSender
					slotId="TestMessageStoreSenderAndListener-Queue"
					sessionKeys="key1,key2">
					<Param name="correlationId" xpathExpression="/Envelope/Header/CorrelationID"/>
				</MessageStoreSender>
				<Forward name="success" path="EXIT"/>
			</SenderPipe>
		</Pipeline>
	</Adapter>

	<!-- This Adapter is for testing with message stores that have lots of messages. Call this pipeline from the page "Test a Pipeline" to instantly fill up the message store with multiple pages -->
	<Adapter name="log-many-messages">
		<Receiver name="log-many-messages-Receiver">
			<JavaListener name="log-many-messages-Listener" serviceName="ibis4test-log-many-messages"/>
			<JdbcErrorStorage slotId="log-many-messages-WriteErrors"/>
		</Receiver>
		<Pipeline>
			<Exits>
				<Exit name="EXIT" state="SUCCESS" code="200"/>
			</Exits>

			<ForPipe name="loop" startAt="0" stopAt="550">
				<Forward name="stop" path="EXIT"/>
				<Forward name="continue" path="sendMessagePipe"/>
			</ForPipe>
			<SenderPipe name="sendMessagePipe">
				<JdbcMessageLog slotId="log-many-messages-WriteLog"/>
				<MessageStoreSender
					slotId="log-many-messages-queue">
					<Param name="messageId" pattern="{uuid}"/>
					<Param name="correlationId" sessionKey="loop.iteration"/>
				</MessageStoreSender>
				<Forward name="success" path="loop"/>
			</SenderPipe>
		</Pipeline>
	</Adapter>
</Module>
