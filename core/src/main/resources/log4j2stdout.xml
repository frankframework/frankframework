<?xml version="1.0" encoding="UTF-8"?>
<log4j2:Configuration status="WARN" name="${ff:instance.name}" strict="true" xmlns="http://logging.apache.org/log4j/2.0/config" xmlns:log4j2="log4j-config.xsd">

	<Properties>
		<Property name="are.we.on.k8s">${env:KUBERNETES_SERVICE_HOST:-false}</Property>
	</Properties>

	<!--  This is for logging with Loki in kubernetes  -->
	<Appenders>
		<Console name="text-stdout">
			<Layout type="PatternLayout">
				<Pattern>%d{yyyy-MM-dd HH:mm:ss,SSS} %-5p %X{configuration,adapter} - %m%n%ex{short}</Pattern>
			</Layout>
		</Console>
		<Console name="json-stdout">
			<JsonTemplateLayout eventTemplateUri="classpath:EcsLayout.json" />
		</Console>

		<Routing name="log-format-appender">
			<Routes pattern="${are.we.on.k8s}">
				<Route ref="json-stdout" key="true" />
				<Route ref="text-stdout" key="false" />
			</Routes>
		</Routing>

		<Async name="stdout">
			<AppenderRef ref="log-format-appender"/>
		</Async>
		<Async name="application-log-appender">
			<AppenderRef ref="log-format-appender"/>
		</Async>
	</Appenders>

	<Loggers>
		<Root level="${ff:log.level}">
			<AppenderRef ref="log-format-appender"/>
		</Root>
	</Loggers>
</log4j2:Configuration>
