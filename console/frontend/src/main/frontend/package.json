{
  "name": "ff-console-gui",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:example": "ng serve -c development-ffexample",
    "start:test": "ng serve -c development-fftest",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "build:analysis": "ng build --configuration analysis",
    "test": "ng test",
    "test:ci": "ng test --no-watch --no-progress --browsers=ChromeHeadless",
    "e2e": "ng e2e",
    "e2e:ci": "ng e2e -c ci",
    "cypress:open": "pnpm -C cypress exec cypress open",
    "cypress:run": "pnpm -C cypress exec cypress run",
    "cypress:ci": "pnpm -C cypress exec cypress run --config baseUrl=http://localhost:8080/iaf-test/iaf/gui",
    "lint": "ng lint"
  },
  "private": true,
